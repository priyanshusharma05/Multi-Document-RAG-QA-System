# OpenRouter API key used for answer generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# You can replace this with any OpenRouter chat model you have access to
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# OpenRouter uses an OpenAI-compatible API endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Use "hashing" when Hugging Face is blocked or unavailable.
# Use "sentence-transformers" when all-MiniLM-L6-v2 is downloaded/cached.
EMBEDDING_BACKEND=hashing
